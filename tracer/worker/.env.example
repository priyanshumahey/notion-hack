# Shared secret for HMAC verification on the ingest webhook.
# Generate with: openssl rand -hex 32
# Set in the worker with: ntn workers env set INGEST_SECRET=<value>
INGEST_SECRET=

# Notion internal integration token, granted access to the worker's databases.
# Required for syncs/webhooks because context.notion is not auto-authenticated
# in those capabilities. Tools get their own client from context.notion.
# Set in the worker with: ntn workers env set NOTION_API_TOKEN=<value>
NOTION_API_TOKEN=

# Optional: pin database IDs to skip a search round-trip on cold start.
# Found in the Notion URL after the first `ntn workers deploy` creates them.
SESSIONS_DB_ID=
TRACES_DB_ID=
SPANS_DB_ID=
LLM_CALLS_DB_ID=
TOOL_CALLS_DB_ID=
EVENTS_DB_ID=
